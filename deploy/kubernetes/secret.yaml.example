# ARMOR Secrets Example
# Copy this file to secret.yaml and fill in your values
# cp secret.yaml.example secret.yaml
#
# IMPORTANT: Do not commit secret.yaml to git!
# It's already in .gitignore, but double-check before pushing.
#
apiVersion: v1
kind: Secret
metadata:
  name: armor-secrets
type: Opaque
stringData:
  # B2 Region (e.g., us-east-005)
  b2-region: ""

  # B2 Application Key ID
  b2-access-key-id: ""

  # B2 Application Key
  b2-secret-access-key: ""

  # B2 Bucket Name
  bucket: ""

  # Cloudflare Domain (CNAME'd to B2 bucket)
  cf-domain: ""

  # Master Encryption Key (32 bytes, hex-encoded = 64 chars)
  # Generate with: openssl rand -hex 32
  master-encryption-key: ""

  # ARMOR Authentication Credentials (for clients)
  # Generate with: openssl rand -hex 16
  auth-access-key: ""

  # Generate with: openssl rand -hex 32
  auth-secret-key: ""
