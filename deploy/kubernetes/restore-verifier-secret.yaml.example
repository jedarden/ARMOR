# Example Secret for restore-verifier
# Copy this file to restore-verifier-secret.yaml and fill in the actual values
# Then apply: kubectl apply -f deploy/kubernetes/restore-verifier-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: restore-verifier-secrets
type: Opaque
stringData:
  # B2 Configuration (same as ARMOR server)
  b2-region: "us-west-004"  # Your B2 region
  b2-endpoint: "s3.us-west-004.backblazeb2.com"  # Your B2 S3 endpoint
  b2-access-key-id: "your-b2-key-id"  # Your B2 application key ID
  b2-secret-access-key: "your-b2-secret-key"  # Your B2 application key

  # Cloudflare domain (optional, for B2 backend)
  cf-domain: "your-cf-domain.example.com"  # Optional

  # Master Encryption Key (MEK) - REQUIRED for direct decryption path
  # This should be the SAME MEK used by the ARMOR server that encrypted the backups
  # Format: 64-character hex string (32 bytes)
  master-encryption-key: "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
